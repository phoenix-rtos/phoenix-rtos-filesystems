NAME := liblfs
LOCAL_HEADERS_DIR := include

# Optional flag for tracing
# LOCAL_CFLAGS += -DLFS_YES_TRACE

ifneq ($(LIBLFS_CACHESIZE_DEFAULT),)
LOCAL_CFLAGS += -DLIBLFS_CACHESIZE_DEFAULT=$(LIBLFS_CACHESIZE_DEFAULT)
endif

ifneq ($(LIBLFS_LOOKAHEAD_SIZE),)
LOCAL_CFLAGS += -DLIBLFS_LOOKAHEAD_SIZE=$(LIBLFS_LOOKAHEAD_SIZE)
endif

ifneq ($(LIBLFS_CYCLES_THRESHOLD),)
LOCAL_CFLAGS += -DLIBLFS_CYCLES_THRESHOLD=$(LIBLFS_CYCLES_THRESHOLD)
endif

ifneq ($(LIBLFS_N_CACHED_OBJECTS),)
LOCAL_CFLAGS += -DLIBLFS_N_CACHED_OBJECTS=$(LIBLFS_N_CACHED_OBJECTS)
endif

ifneq ($(LIBLFS_LINK_IS_RENAME),)
LOCAL_CFLAGS += -DLIBLFS_LINK_IS_RENAME=$(LIBLFS_LINK_IS_RENAME)
endif

ifneq ($(LIBLFS_MOUNT_FORMAT_OPTION),)
LOCAL_CFLAGS += -DLIBLFS_MOUNT_FORMAT_OPTION=$(LIBLFS_MOUNT_FORMAT_OPTION)
endif

ifneq ($(LIBLFS_FORMAT_ON_MOUNT_FAILURE),)
LOCAL_CFLAGS += -DLIBLFS_FORMAT_ON_MOUNT_FAILURE=$(LIBLFS_FORMAT_ON_MOUNT_FAILURE)
endif

LOCAL_SRCS := lfs.c lfs_bd.c lfs_util.c ph_lfs_api.c liblfs.c

include $(static-lib.mk)
